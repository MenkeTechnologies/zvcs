{
  "command": "bundle",
  "mutating": false,
  "flags": [
    "-q",
    "--quiet",
    "--progress",
    "--version=2",
    "--version=3",
    "--version=9",
    "--version=bogus",
    "--all",
    "--branches",
    "--tags",
    "--remotes",
    "--branches --tags",
    "--not --all",
    "--max-count=1",
    "--since=10.days.ago",
    "--until=10.days.ago",
    "--filter=blob:none",
    "--filter=tree:0",
    "--filter=bogus",
    "--bogus-flag",
    "-Z"
  ],
  "positionals": [
    "create",
    "verify",
    "list-heads",
    "-",
    "HEAD",
    "main",
    "feature",
    "v0.1.0",
    "v0.2.0",
    "refs/heads/main",
    "refs/tags/v0.2.0",
    "main~1..main",
    "^main",
    "does-not-exist",
    "bogus-subcommand",
    "--bogus-option",
    ""
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
}
