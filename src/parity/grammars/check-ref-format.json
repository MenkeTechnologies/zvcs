{
  "command": "check-ref-format",
  "mutating": false,
  "flags": [
    "--normalize",
    "--print",
    "--allow-onelevel",
    "--no-allow-onelevel",
    "--refspec-pattern",
    "--branch"
  ],
  "positionals": [
    "",
    "refs/heads/main",
    "refs/heads/feature",
    "refs/tags/v0.1.0",
    "refs/tags/v0.2.0",
    "refs/remotes/origin/main",
    "main",
    "feature",
    "HEAD",
    "@",
    "@{-1}",
    "does-not-exist",
    "refs/heads/does-not-exist",
    "refs/heads/foo.lock",
    "refs/heads/.hidden",
    "refs/heads/foo..bar",
    "refs/heads/foo.",
    "refs/heads/foo bar",
    "refs/heads/foo~1",
    "refs/heads/foo^",
    "refs/heads/foo:bar",
    "refs/heads/foo?bar",
    "refs/heads/foo*bar",
    "refs/heads/foo[bar",
    "refs/heads/foo\\bar",
    "refs/heads/foo@{1}",
    "refs/heads//foo",
    "refs/heads/foo/",
    "/refs/heads/foo",
    "//refs//heads//foo",
    "refs/heads/foo*/bar",
    "refs/heads/foo*/bar*",
    "-dashy",
    "refs/heads/-dashy",
    "src/lib.rs",
    "README.md"
  ],
  "shapes": [
    "linear",
    "branched",
    "detached"
  ]
}
