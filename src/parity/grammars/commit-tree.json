{
  "command": "commit-tree",
  "mutating": true,
  "flags": [
    "-m x",
    "-m",
    "-m first -m second",
    "-m first -m second -m third",
    "-m trailing-newline-check",
    "-F README.md",
    "-F src/lib.rs",
    "-F does-not-exist",
    "-m x -F README.md",
    "-F README.md -m x",
    "-p HEAD -m x",
    "-p main -m x",
    "-p feature -m x",
    "-p v0.1.0 -m x",
    "-p v0.2.0 -m x",
    "-p HEAD -p feature -m x",
    "-p HEAD -p HEAD -m x",
    "-p HEAD^{tree} -m x",
    "-p does-not-exist -m x",
    "-p HEAD -m x -F README.md",
    "--no-gpg-sign -m x",
    "--no-gpg-sign -p HEAD -m x",
    "-m x --"
  ],
  "positionals": [
    "HEAD^{tree}",
    "main^{tree}",
    "feature^{tree}",
    "v0.1.0^{tree}",
    "v0.2.0^{tree}",
    "HEAD~1^{tree}",
    "HEAD:src",
    "4b825dc642cb6eb9a060e54bf8d69288fbee4904",
    "HEAD",
    "HEAD:README.md",
    "",
    "does-not-exist"
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
}
