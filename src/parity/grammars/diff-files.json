    "-s",
    "--no-patch",
    "-U0",
    "-U1",
    "--unified=5",
    "--raw",
    "--patch-with-raw",
    "--output-indicator-new=>",
    "--output-indicator-old=<",
    "--output-indicator-context=~",
    "--indent-heuristic",
    "--no-indent-heuristic",
    "--minimal",
    "--patience",
    "--histogram",
    "--anchored=fn",
    "--diff-algorithm=myers",
    "--diff-algorithm=minimal",
    "--diff-algorithm=patience",
    "--diff-algorithm=histogram",
    "--diff-algorithm=bogus",
    "--stat",
    "--stat=120",
    "--stat=120,40",
    "--stat-width=100",
    "--stat-name-width=30",
    "--stat-count=1",
    "--stat-graph-width=20",
    "--compact-summary",
    "--numstat",
    "--shortstat",
    "--dirstat",
    "--dirstat=files,10",
    "--dirstat-by-file",
    "--cumulative",
    "--summary",
    "--patch-with-stat",
    "-z",
    "--name-only",
    "--name-status",
    "--submodule",
    "--submodule=short",
    "--submodule=log",
    "--submodule=diff",
    "--color=never",
    "--color=always",
    "--no-color",
    "--color-moved",
    "--color-moved=zebra",
    "--no-color-moved",
    "--color-moved-ws=ignore-all-space",
    "--no-color-moved-ws",
    "--word-diff",
    "--word-diff=porcelain",
    "--word-diff=plain",
    "--word-diff-regex=[a-z]+",
    "--color-words",
    "--no-renames",
    "--rename-empty",
    "--no-rename-empty",
    "--check",
    "--ws-error-highlight=all",
    "--ws-error-highlight=none",
    "--full-index",
    "--binary",
    "--abbrev",
    "--abbrev=4",
    "--abbrev=40",
    "-B",
    "-B50/60",
    "--break-rewrites",
    "-M",
    "-M50%",
    "--find-renames=30%",
    "-C",
    "--find-copies=40%",
    "--find-copies-harder",
    "-D",
    "--irreversible-delete",
    "-l100",
    "--diff-filter=M",
    "--diff-filter=ACDMRTUXB",
    "--diff-filter=d",
    "-Sfn",
    "-Gfn",
    "--pickaxe-all",
    "--pickaxe-regex",
    "--skip-to=src/lib.rs",
    "--rotate-to=README.md",
    "-R",
    "--relative",
    "--relative=src",
    "--no-relative",
    "-a",
    "--text",
    "--ignore-cr-at-eol",
    "--ignore-space-at-eol",
    "-b",
    "--ignore-space-change",
    "-w",
    "--ignore-all-space",
    "--ignore-blank-lines",
    "-Ifn",
    "--ignore-matching-lines=^fn",
    "--inter-hunk-context=2",
    "-W",
    "--function-context",
    "--exit-code",
    "--quiet",
    "--ext-diff",
    "--no-ext-diff",
    "--textconv",
    "--no-textconv",
    "--ignore-submodules",
    "--ignore-submodules=none",
    "--ignore-submodules=untracked",
    "--ignore-submodules=dirty",
    "--ignore-submodules=all",
    "--src-prefix=a/",
    "--dst-prefix=b/",
    "--no-prefix",
    "--default-prefix",
    "--line-prefix=| ",
    "--ita-invisible-in-index",
    "-0",
    "-1",
    "--base",
    "-2",
    "--ours",
    "-3",
    "--theirs",
    "-c",
    "--cc",
    "-q",
    "--bogus-flag",
    "--"
  ],
  "positionals": [
    "",
    "README.md",
    "src/lib.rs",
    "src",
    "src/",
    "./README.md",
    "*.md",
    "src/*.rs",
    ":(glob)src/**/*.rs",
    ":!README.md",
    ":(icase)readme.md",
    "does-not-exist",
    "src/does-not-exist.rs",
    "-not-a-flag"
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
