{
  "command": "diff-index",
  "mutating": false,
  "flags": [
    "-p",
    "-u",
    "--patch",
    "-s",
    "--no-patch",
    "-U0",
    "--unified=5",
    "--raw",
    "--patch-with-raw",
    "--indent-heuristic",
    "--no-indent-heuristic",
    "--minimal",
    "--patience",
    "--histogram",
    "--anchored=fn",
    "--diff-algorithm=myers",
    "--diff-algorithm=patience",
    "--diff-algorithm=minimal",
    "--diff-algorithm=histogram",
    "--stat",
    "--stat=120,60,3",
    "--stat-width=100",
    "--stat-name-width=40",
    "--stat-count=2",
    "--compact-summary",
    "--numstat",
    "--shortstat",
    "--dirstat",
    "--dirstat=files,10,cumulative",
    "--dirstat=lines",
    "--cumulative",
    "--dirstat-by-file",
    "--summary",
    "--patch-with-stat",
    "-z",
    "--name-only",
    "--name-status",
    "--submodule",
    "--submodule=short",
    "--submodule=log",
    "--submodule=diff",
    "--color=never",
    "--color=always",
    "--no-color",
    "--color-moved",
    "--color-moved=zebra",
    "--color-moved=plain",
    "--no-color-moved",
    "--color-moved-ws=allow-indentation-change",
    "--color-moved-ws=ignore-all-space",
    "--no-color-moved-ws",
    "--word-diff",
    "--word-diff=plain",
    "--word-diff=porcelain",
    "--word-diff=color",
    "--word-diff-regex=[A-Za-z_]+",
    "--color-words",
    "--no-renames",
    "--rename-empty",
    "--no-rename-empty",
    "--check",
    "--ws-error-highlight=all",
    "--ws-error-highlight=old,new",
    "--full-index",
    "--binary",
    "--abbrev",
    "--abbrev=8",
    "-B",
    "-B20/60",
    "--break-rewrites",
    "--break-rewrites=20/60",
    "-M",
    "-M50",
    "--find-renames=50",
    "-C",
    "-C50",
    "--find-copies=50",
    "--find-copies-harder",
    "-D",
    "--irreversible-delete",
    "-l100",
    "--diff-filter=M",
    "--diff-filter=ACDMRTUXB",
    "--diff-filter=d",
    "-Sfn",
    "-Gfn",
    "--pickaxe-all",
    "--pickaxe-regex",
    "--skip-to=README.md",
    "--rotate-to=README.md",
    "-R",
    "--relative",
    "--relative=src",
    "--no-relative",
    "-a",
    "--text",
    "--ignore-cr-at-eol",
    "--ignore-space-at-eol",
    "-b",
    "--ignore-space-change",
    "-w",
    "--ignore-all-space",
    "--ignore-blank-lines",
    "-Ifn",
    "--ignore-matching-lines=fn",
    "--inter-hunk-context=2",
    "-W",
    "--function-context",
    "--exit-code",
    "--quiet",
    "--no-ext-diff",
    "--no-textconv",
    "--ignore-submodules",
    "--ignore-submodules=none",
    "--ignore-submodules=untracked",
    "--ignore-submodules=dirty",
    "--ignore-submodules=all",
    "--src-prefix=old/",
    "--dst-prefix=new/",
    "--no-prefix",
    "--default-prefix",
    "--line-prefix=> ",
    "--ita-invisible-in-index",
    "--output-indicator-new=>",
    "--output-indicator-old=<",
    "--output-indicator-context=~",
    "--cached",
    "--merge-base",
    "-m"
  ],
  "positionals": [
    "HEAD",
    "HEAD --",
    "HEAD README.md",
    "HEAD src/lib.rs",
    "HEAD src",
    "HEAD -- README.md src/lib.rs",
    "HEAD -- does-not-exist",
    "HEAD^{tree}",
    "HEAD~1",
    "main",
    "feature",
    "v0.1.0",
    "v0.2.0",
    "v0.2.0 -- src",
    "main feature",
    "",
    "does-not-exist",
    "HEAD -- 'sp ace.txt'"
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
}
