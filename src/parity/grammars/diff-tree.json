  "positionals": [
    "HEAD",
    "HEAD~1",
    "HEAD^",
    "main",
    "feature",
    "v0.1.0",
    "v0.2.0",
    "HEAD^{tree}",
    "main^{tree}",
    "HEAD~1 HEAD",
    "main feature",
    "v0.1.0 v0.2.0",
    "HEAD HEAD",
    "main^{tree} feature^{tree}",
    "HEAD~1 HEAD README.md",
    "main feature src/lib.rs",
    "HEAD README.md src/lib.rs",
    "HEAD -- README.md",
    "HEAD~1 HEAD -- src",
    "HEAD src",
    "HEAD does-not-exist.txt",
    "does-not-exist",
    "HEAD does-not-exist",
    "0000000000000000000000000000000000000000",
    "README.md",
    ""
