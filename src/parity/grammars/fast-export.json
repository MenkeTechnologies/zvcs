{
  "command": "fast-export",
  "mutating": false,
  "flags": [
    "--all",
    "--branches",
    "--tags",
    "--no-data",
    "--full-tree",
    "--use-done-feature",
    "--mark-tags",
    "--fake-missing-tagger",
    "--show-original-ids",
    "--reference-excluded-parents",
    "--anonymize",
    "--anonymize-map=README.md:DOC.md",
    "--anonymize-map=src",
    "-M",
    "-C",
    "--progress=1",
    "--progress=2",
    "--signed-tags=verbatim",
    "--signed-tags=warn-verbatim",
    "--signed-tags=warn-strip",
    "--signed-tags=strip",
    "--signed-tags=abort",
    "--signed-commits=verbatim",
    "--signed-commits=warn-verbatim",
    "--signed-commits=warn-strip",
    "--signed-commits=strip",
    "--signed-commits=abort",
    "--tag-of-filtered-object=abort",
    "--tag-of-filtered-object=drop",
    "--tag-of-filtered-object=rewrite",
    "--reencode=yes",
    "--reencode=no",
    "--reencode=abort",
    "--refspec=refs/heads/*:refs/heads/exported/*",
    "--refspec=refs/heads/main:refs/heads/trunk",
    "--reverse",
    "--topo-order",
    "--date-order",
    "--first-parent",
    "--no-merges",
    "--max-count=1",
    "--max-count=3",
    "--skip=1",
    "--simplify-merges",
    "--ancestry-path",
    "--full-history",
    "--sparse",
    "--dense",
    "--not",
    "--boundary",
    "--remotes",
    "--reflog",
    "--invalid-flag"
  ],
  "positionals": [
    "HEAD",
    "main",
    "feature",
    "v0.1.0",
    "v0.2.0",
    "main..feature",
    "feature..main",
    "main...feature",
    "HEAD~1..HEAD",
    "--all",
    "-- README.md",
    "-- src/lib.rs",
    "does-not-exist",
    ""
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
}
