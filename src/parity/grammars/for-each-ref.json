{
  "command": "for-each-ref",
  "mutating": false,
  "flags": [
    "--count=1",
    "--count=3",
    "--count=0",
    "--sort=refname",
    "--sort=-refname",
    "--sort=objecttype",
    "--sort=-committerdate",
    "--sort=taggerdate",
    "--sort=*objecttype",
    "--sort=creatordate",
    "--sort=upstream",
    "--sort=does-not-exist",
    "--format=%(refname)",
    "--format=%(refname:short)",
    "--format=%(refname:lstrip=2)",
    "--format=%(refname:rstrip=1)",
    "--format=%(objectname)",
    "--format=%(objectname:short)",
    "--format=%(objectname:short=12)",
    "--format=%(objecttype) %(objectsize) %(refname)",
    "--format=%(*objectname) %(*objecttype)",
    "--format=%(HEAD) %(refname:short)",
    "--format=%(upstream:short) %(upstream:track)",
    "--format=%(push:short)",
    "--format=%(symref)",
    "--format=%(contents:subject)",
    "--format=%(contents:body)",
    "--format=%(subject) %(body)",
    "--format=%(authorname) <%(authoremail)> %(authordate:iso8601)",
    "--format=%(committername) %(committerdate:short)",
    "--format=%(taggername) %(taggerdate:relative)",
    "--format=%(creator) %(creatordate:unix)",
    "--format=%(align:25,left)%(refname:short)%(end)|",
    "--format=%(align:width=25,position=right)%(refname:short)%(end)|",
    "--format=%(if)%(HEAD)%(then)cur%(else)oth%(end) %(refname)",
    "--format=%(if:equals=main)%(refname:short)%(then)MAIN%(end)",
    "--format=%(color:red)%(refname)%(color:reset)",
    "--format=%(objectname)%09%(refname)",
    "--format=%(refname)%00%(objecttype)",
    "--format=%%%(refname)",
    "--format=",
    "--format=%(bogusfield)",
    "--format",
    "--color=always",
    "--color=never",
    "--color=auto",
    "--color",
    "--shell",
    "--perl",
    "--python",
    "--tcl",
    "--points-at=HEAD",
    "--points-at=main",
    "--points-at=v0.1.0",
    "--points-at=v0.2.0",
    "--points-at=does-not-exist",
    "--merged",
    "--merged=HEAD",
    "--merged=main",
    "--merged=feature",
    "--no-merged",
    "--no-merged=HEAD",
    "--no-merged=main",
    "--contains",
    "--contains=HEAD",
    "--contains=main",
    "--no-contains",
    "--no-contains=HEAD",
    "--ignore-case",
    "--omit-empty",
    "--exclude=refs/tags/*",
    "--exclude=refs/heads/feature",
    "--exclude=refs/remotes/*",
    "--include-root-refs",
    "--start-after=refs/heads/main",
    "--start-after=refs/tags/v0.1.0",
    "--start-after=",
    "--bogus-flag"
  ],
  "positionals": [
    "",
    "refs/heads/*",
    "refs/tags/*",
    "refs/heads/",
    "refs/heads/main",
    "refs/heads/feature",
    "refs/tags/v0.1.0",
    "refs/tags/v0.2.0",
    "refs/*",
    "refs/**",
    "main",
    "*feature*",
    "refs/heads/[mf]*",
    "REFS/HEADS/MAIN",
    "refs/does-not-exist/*",
    "does-not-exist",
    "refs/heads/* refs/tags/*"
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
}
