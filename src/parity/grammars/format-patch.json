    "--subject-prefix=RFC PATCH",
    "--subject-prefix=",
    "--cover-letter",
    "--no-cover-letter",
    "--cover-from-description=message",
    "--cover-from-description=subject",
    "--cover-from-description=auto",
    "--cover-from-description=none",
    "--cover-from-description=bogus",
    "--commit-list-format=%h %s",
    "--commit-list-format=%an",
    "-v 2",
    "--reroll-count=3",
    "--reroll-count=0",
    "--reroll-count=v2-rebased",
    "--always",
    "--root",
    "--ignore-if-in-upstream",
    "--zero-commit",
    "--no-zero-commit",
    "--attach",
    "--attach=BOUNDARY123",
    "--no-attach",
    "--inline",
    "--inline=BOUNDARY123",
    "--thread",
    "--thread=shallow",
    "--thread=deep",
    "--thread=bogus",
    "--no-thread",
    "--in-reply-to=<msg-id@example.com>",
    "--to=user@example.com",
    "--cc=other@example.com",
    "--add-header=X-Test: value",
    "--from",
    "--from=Example User <user@example.com>",
    "--force-in-body-from",
    "--no-force-in-body-from",
    "--encode-email-headers",
    "--no-encode-email-headers",
    "--signature=custom sig",
    "--signature=",
    "--no-signature",
    "--signature-file=README.md",
    "--signature-file=does-not-exist",
    "--description-file=README.md",
    "--description-file=does-not-exist",
    "--notes",
