    "--progress",
    "--no-progress",
    "-o patches",
    "--output-directory=patches",
    "-o .",
    "-p",
    "--no-stat",
    "-U0",
    "-U5",
    "--unified=1",
    "--indent-heuristic",
    "--no-indent-heuristic",
    "--minimal",
    "--patience",
    "--histogram",
    "--anchored=fn",
    "--diff-algorithm=myers",
    "--diff-algorithm=minimal",
    "--diff-algorithm=patience",
    "--diff-algorithm=histogram",
    "--diff-algorithm=bogus",
    "--stat",
    "--stat=80",
    "--stat=200,50,3",
    "--stat-width=60",
    "--stat-name-width=20",
    "--stat-count=1",
    "--compact-summary",
    "--numstat",
    "--shortstat",
    "--dirstat",
    "--dirstat=files,10,cumulative",
    "--dirstat=lines",
    "--dirstat-by-file",
    "--cumulative",
    "--summary",
    "--no-renames",
    "--rename-empty",
    "--no-rename-empty",
    "--full-index",
    "--binary",
    "--no-binary",
    "--abbrev",
    "--abbrev=4",
    "--abbrev=40",
    "-B",
    "-B50/60",
    "--break-rewrites",
    "-M",
    "-M50%",
    "--find-renames=30%",
    "-C",
    "--find-copies=40%",
    "--find-copies-harder",
    "-D",
    "--irreversible-delete",
    "-l100",
    "--skip-to=README.md",
    "--rotate-to=README.md",
    "--relative",
    "--relative=src",
    "--no-relative",
    "-a",
    "--text",
    "--ignore-cr-at-eol",
    "--ignore-space-at-eol",
    "-b",
    "--ignore-space-change",
    "-w",
    "--ignore-all-space",
    "--ignore-blank-lines",
    "-I^$",
    "--ignore-matching-lines=^fn",
    "--inter-hunk-context=2",
    "-W",
    "--function-context",
    "--no-ext-diff",
    "--textconv",
    "--no-textconv",
    "--ignore-submodules=all",
    "--ignore-submodules=dirty",
    "--ignore-submodules=none",
    "--src-prefix=a/",
    "--dst-prefix=b/",
    "--no-prefix",
    "--default-prefix",
    "--line-prefix=> ",
    "--ita-invisible-in-index",
    "--output-indicator-new=>",
    "--output-indicator-old=<",
    "--output-indicator-context=~",
    "--no-color",
    "--color=never",
    "--no-walk",
    "--reverse",
    "--max-count=2",
    "--skip=1",
    "--first-parent",
    "--no-merges",
    "--min-parents=1",
    "--max-parents=1",
    "--topo-order",
    "--date-order",
    "--author-date-order"
  ],
  "positionals": [
    "",
    "HEAD",
    "HEAD~1",
    "HEAD~2",
    "HEAD^",
    "main",
    "feature",
    "v0.1.0",
    "v0.2.0",
    "main..feature",
    "feature..main",
    "HEAD~2..HEAD",
    "HEAD~1..HEAD",
    "v0.1.0..v0.2.0",
    "v0.1.0..HEAD",
    "main...feature",
    "HEAD..HEAD",
    "main feature",
    "HEAD~2 HEAD",
    "HEAD~2..HEAD -- README.md",
    "main..feature -- src/lib.rs",
    "HEAD~1..HEAD -- src",
    "HEAD~1..HEAD -- does-not-exist",
    "^main feature",
    "0000000000000000000000000000000000000000",
    "does-not-exist",
    "does-not-exist..HEAD",
    "README.md"
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
}
