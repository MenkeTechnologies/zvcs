{
  "command": "format-patch",
  "mutating": false,
  "flags": [
    "--stdout",
    "-1",
    "-2",
    "-3",
    "-n",
    "--numbered",
    "-N",
    "--no-numbered",
    "--start-number=5",
    "--start-number=0",
    "--numbered-files",
    "-k",
    "--keep-subject",
    "-s",
    "--signoff",
    "--no-signoff",
    "--suffix=.txt",
    "--suffix=.mbox",
    "--suffix=",
    "--filename-max-length=20",
    "--filename-max-length=5",
    "--rfc",
