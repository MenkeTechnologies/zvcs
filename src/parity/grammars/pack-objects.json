{
  "command": "pack-objects",
  "mutating": false,
  "flags": [
    "--stdout",
    "--revs",
    "--all",
    "--unpacked",
    "--reflog",
    "--indexed-objects",
    "--include-tag",
    "--stdin-packs",
    "--non-empty",
    "--local",
    "--incremental",
    "--honor-pack-keep",
    "--keep-true-parents",
    "--delta-base-offset",
    "--no-reuse-delta",
    "--no-reuse-object",
    "--sparse",
    "--no-sparse",
    "--thin",
    "--shallow",
    "--cruft",
    "--cruft-expiration=now",
    "--delta-islands",
    "--path-walk",
    "--use-bitmap-index",
    "--no-use-bitmap-index",
    "--exclude-promisor-objects",
    "-q",
    "--progress",
    "--all-progress",
    "--all-progress-implied",
    "--window=0",
    "--window=10",
    "--window=250",
    "--depth=1",
    "--depth=50",
    "--depth=4095",
    "--window-memory=0",
    "--window-memory=16m",
    "--max-pack-size=1m",
    "--compression=0",
    "--compression=1",
    "--compression=9",
    "--threads=1",
    "--threads=2",
    "--index-version=1",
    "--index-version=2",
    "--name-hash-version=1",
    "--name-hash-version=2",
    "--filter=blob:none",
    "--filter=blob:limit=1k",
    "--filter=tree:0",
    "--filter=object:type=commit",
    "--no-filter",
    "--missing=allow-any",
    "--missing=allow-promisor",
    "--keep-pack=pack-does-not-exist.pack"
  ],
  "positionals": [
    "",
    "no-such-dir/does-not-exist"
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
}
