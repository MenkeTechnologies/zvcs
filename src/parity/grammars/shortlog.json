{
  "command": "shortlog",
  "mutating": false,
  "flags": [
    "-n",
    "--numbered",
    "--no-numbered",
    "-s",
    "--summary",
    "--no-summary",
    "-e",
    "--email",
    "--no-email",
    "-c",
    "--committer",
    "--group=author",
    "--group=committer",
    "--group=trailer:signed-off-by",
    "--group=trailer:co-authored-by",
    "--group=trailer:reviewed-by",
    "--group=format:%h",
    "--group=format:%an",
    "--group=format:%ae",
    "--group=format:%cd",
    "--group=bogus",
    "--format=%h %s",
    "--format=* [%h] %s",
    "--format=%H",
    "--format=%an <%ae>",
    "--format=%s",
    "--format=%cn",
    "--format=",
    "--format=%(bogus)",
    "--format=oneline",
    "--format=short",
    "--format=medium",
    "--format=full",
    "--date=iso",
    "--date=iso-strict",
    "--date=rfc2822",
    "--date=short",
    "--date=raw",
    "--date=unix",
    "--date=relative",
    "--date=human",
    "--date=default",
    "--date=format:%Y-%m",
    "--date=bogus",
    "-w",
    "-w0",
    "-w80",
    "-w80,4,8",
    "-w20,0,0",
    "-w1",
    "-w0,0,0",
    "--max-count=1",
    "--max-count=0",
    "-1",
    "-2",
    "--skip=1",
    "--skip=100",
    "--since=1 year ago",
    "--since=2099-01-01",
    "--until=now",
    "--before=now",
    "--after=1 year ago",
    "--author=a",
    "--author=does-not-match",
    "--committer=a",
    "--grep=commit",
    "--grep=init",
    "--grep=does-not-match-anything",
    "--all-match",
    "--invert-grep",
    "-i",
    "--regexp-ignore-case",
    "--basic-regexp",
    "-E",
    "--extended-regexp",
    "-F",
    "--fixed-strings",
    "-P",
    "--perl-regexp",
    "--merges",
    "--no-merges",
    "--min-parents=2",
    "--max-parents=1",
    "--max-parents=0",
    "--no-min-parents",
    "--no-max-parents",
    "--first-parent",
    "--exclude-first-parent-only",
    "--all",
    "--branches",
    "--branches=feat*",
    "--tags",
    "--tags=v0*",
    "--remotes",
    "--glob=refs/heads/*",
    "--exclude=refs/heads/feature",
    "--reflog",
    "--single-worktree",
    "--ignore-missing",
    "--reverse",
    "--topo-order",
    "--date-order",
    "--author-date-order",
    "--boundary",
    "--ancestry-path",
    "--simplify-merges",
    "--full-history",
    "--sparse",
    "--dense",
    "--remove-empty",
    "--not",
    "--bogus-flag",
    "-Z"
  ],
  "positionals": [
    "",
    "HEAD",
    "HEAD~1",
    "main",
    "feature",
    "refs/heads/main",
    "refs/heads/feature",
    "v0.1.0",
    "v0.2.0",
    "main..feature",
    "main...feature",
    "feature ^main",
    "HEAD -- README.md",
    "HEAD -- src/lib.rs",
    "HEAD -- src/",
    "HEAD -- does-not-exist",
    "-- README.md",
    "HEAD README.md",
    "refs/heads/does-not-exist",
    "does-not-exist",
    "does-not-exist..HEAD"
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached",
    "awkward-paths",
    "submodule"
  ]
}
