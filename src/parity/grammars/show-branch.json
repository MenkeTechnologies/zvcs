{
  "command": "show-branch",
  "mutating": false,
  "flags": [
    "-a",
    "--all",
    "-r",
    "--remotes",
    "--current",
    "--topo-order",
    "--date-order",
    "--sparse",
    "--more=1",
    "--more=3",
    "--more=-1",
    "--list",
    "--merge-base",
    "--independent",
    "--no-name",
    "--sha1-name",
    "--topics",
    "-g",
    "--reflog",
    "--reflog=3",
    "--reflog=2,1",
    "--color",
    "--color=always",
    "--color=never",
    "--color=auto",
    "--no-color"
  ],
  "positionals": [
    "",
    "HEAD",
    "main",
    "feature",
    "main feature",
    "v0.1.0",
    "v0.2.0",
    "HEAD~1",
    "heads/*",
    "refs/heads/main",
    "does-not-exist",
    "README.md"
  ],
  "shapes": [
    "linear",
    "branched",
    "merged",
    "dirty",
    "conflicted",
    "detached"
  ]
}
